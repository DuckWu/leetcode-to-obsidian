{
  "manifest_version": 3,
  "name": "LeetCode → Obsidian 题型归档",
  "version": "1.0.0",
  "description": "LeetCode 提交 Accepted 后，自动调用 DeepSeek 归类题型，写入 Obsidian 知识库。",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://leetcode.com/*",
    "https://leetcode.cn/*",
    "https://api.deepseek.com/*",
    "http://127.0.0.1:27123/*",
    "http://localhost:27123/*",
    "https://127.0.0.1:27124/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*", "https://leetcode.cn/problems/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://leetcode.com/problems/*", "https://leetcode.cn/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "service-worker.js"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
